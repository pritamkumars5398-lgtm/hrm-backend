// Access-control (users, organisations, invites) plus the real HR business
// modules built on top of it: employees, attendance, leave, payroll,
// performance, documents. There are deliberately no models yet for reports —
// that stays mock-only until its own turn (CLAUDE.md §11.4).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model User {
  // A plain string _id, not an ObjectId, so seeded ids stay readable (usr-1).
  id             String  @id @map("_id")
  email          String  @unique
  // bcrypt hash. Empty for Google accounts, which have no local password.
  passwordHash   String
  requiresPasswordReset Boolean @default(false)
  name           String
  avatarInitials String
  createdAt      DateTime @default(now())
  // FCM registration tokens — one per browser/device the user has registered
  // push on. A plain array, not a separate model: nothing else ever queries
  // "which user owns this token" independently of the user itself.
  fcmTokens      String[] @default([])
}

type FinancialDetails {
  accName   String
  accNumber String
  bankName  String
  ifscCode  String
}

type EducationDetail {
  degree      String
  institution String
  year        String
}

type FamilyDetail {
  name          String
  relationship  String
  contactNumber String?
}

model Employee {
  id               String   @id @map("_id")
  userId           String
  organizationId   String
  // Optional because MongoDB is schemaless: Employee records created before these
  // fields existed have no value for them, and reads must not fail on that null.
  employeeId       String?
  firstName        String
  lastName         String
  // Self-reference to another Employee.id in the same org — "who does this
  // person report to." Plain string, not a Prisma relation, matching every
  // other cross-reference in this schema (organizationId, userId, etc.);
  // resolved in application code. Nullable: not everyone has a manager.
  managerId        String?
  contactNumber    String?
  homeAddress      String?
  // Cloudinary secure_url. Set via the signed direct-upload flow (photo bytes
  // never pass through this server) — see cloudinary-signature.ts.
  photoUrl         String?
  jobTitle         String
  department       String
  startDate        DateTime
  employmentType   String
  workLocation     String
  financialDetails FinancialDetails?
  educationDetails EducationDetail[]
  familyDetails    FamilyDetail[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime? @updatedAt
  // Soft delete (§6): the row is retained, reads filter on `deletedAt: null`.
  deletedAt        DateTime?

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Membership {
  id             String   @id @map("_id")
  userId         String
  organizationId String
  jobTitle       String
  permissions    String[]
  createdAt      DateTime @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Organization {
  id        String   @id @map("_id")
  name      String
  address   String
  industry  String
  ownerId   String
  createdAt DateTime @default(now())
  // Where a "someone applied for leave" email goes. Optional — no address, no email.
  leaveNotificationEmail String?
  // Yearly leave entitlement, per type. Null means "use the default" (LEAVE_ENTITLEMENT).
  leaveAnnualDays   Int?
  leaveSickDays     Int?
  leavePersonalDays Int?

  // How payday is described to employees — doesn't affect payroll math (§ pay
  // cycle), purely informational. Null means "not set up yet".
  payCycleType       String? // FIXED | RANGE
  // Day-of-month, used when FIXED.
  payCycleFixedDay   Int?
  // Day-of-month range, used when RANGE — e.g. 1-7 for "first week".
  payCycleRangeStart Int?
  payCycleRangeEnd   Int?
}

model Invite {
  id             String   @id @map("_id")
  organizationId String
  email          String
  permissions    String[]
  status         String
  // The credential that grants access to an organisation — unique and unguessable.
  token          String   @unique
  invitedBy      String
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([organizationId])
}

model AttendanceRecord {
  id             String    @id @map("_id")
  organizationId String
  employeeId     String
  // Plain YYYY-MM-DD, not DateTime — one record per employee per calendar day,
  // and this sidesteps timezone edge cases when matching "today".
  date           String
  checkIn        DateTime?
  checkOut       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt

  @@unique([employeeId, date])
  @@index([organizationId, date])
}

model SalaryStructure {
  id             String   @id @map("_id")
  organizationId String
  employeeId     String
  basic          Float
  hra            Float    @default(0)
  otherAllowance Float    @default(0)
  // The 1st-of-month a raise/revision takes effect from (YYYY-MM-DD) — a salary
  // change always applies from a whole pay cycle, never mid-month. Revising
  // creates a new row rather than editing the old one, so a payslip already run
  // against an earlier structure keeps its own snapshot values and stays correct
  // even after a later raise.
  effectiveFrom   String
  createdAt       DateTime @default(now())
  createdByUserId String

  @@unique([employeeId, effectiveFrom])
  @@index([organizationId, employeeId, effectiveFrom])
}

// Frozen at finalize time — a later salary revision or attendance correction
// must never change what a finalized payslip already showed someone.
type PayslipSnapshot {
  basic           Float
  hra             Float
  otherAllowance  Float
  daysInMonth     Int
  // Unpaid days: ABSENT (no check-in, no approved leave) and UNPAID-type leave
  // count as 1, HALF_DAY counts as 0.5. Weekends are never unpaid.
  unpaidDays      Float
  lopDeduction    Float
  grossEarnings   Float
  totalDeductions Float
  netSalary       Float
}

model Payslip {
  id             String   @id @map("_id")
  organizationId String
  employeeId     String
  // YYYY-MM
  month          String
  status         String // DRAFT | FINALIZED

  // Owner-entered, editable only while DRAFT.
  bonus          Float   @default(0)
  incentive      Float   @default(0)
  reimbursement  Float   @default(0)
  otherEarnings  Float   @default(0)
  incomeTax      Float   @default(0)
  otherDeduction Float   @default(0)
  notes          String?

  // Only set once status = FINALIZED (§ payslip snapshot above).
  snapshot PayslipSnapshot?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime? @updatedAt
  finalizedAt        DateTime?
  finalizedByUserId  String?

  @@unique([employeeId, month])
  @@index([organizationId, month])
}

// One per org at a time in OPEN status — enforced in AppraisalCycle lookup,
// not a DB constraint (Mongo has no partial-unique-index support in Prisma).
// Auto-vivified (named after the current calendar quarter) the first time
// anyone in an org loads Performance — there is no cycle-management UI yet.
model AppraisalCycle {
  id             String    @id @map("_id")
  organizationId String
  name           String
  status         String // OPEN | CLOSED
  startDate      String // YYYY-MM-DD
  endDate        String
  createdAt      DateTime  @default(now())
  closedAt       DateTime?

  @@index([organizationId, status])
}

model Goal {
  id             String    @id @map("_id")
  organizationId String
  employeeId     String
  cycleId        String
  title          String
  progress       Int       @default(0)
  dueOn          String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt

  @@index([organizationId, employeeId, cycleId])
}

model Review {
  id              String   @id @map("_id")
  organizationId  String
  employeeId      String
  cycleId         String
  rating          Int
  summary         String
  reviewerUserId  String
  createdAt       DateTime @default(now())

  // One review per employee per cycle — matches the frontend's "Pending" vs.
  // "Reviewed" toggle, which has no concept of re-reviewing within a cycle.
  @@unique([employeeId, cycleId])
  @@index([organizationId, cycleId])
}

model Document {
  id             String    @id @map("_id")
  organizationId String
  name           String
  description    String
  category       String // Policies | Templates | Contracts | Compliance | Onboarding
  fileType       String // PDF | DOCX | XLSX
  sizeKb         Int
  cloudinaryPublicId     String
  // Cloudinary requires the matching resource_type ('image' | 'raw') at
  // delete time — stored alongside the id rather than re-derived from fileType.
  cloudinaryResourceType String
  cloudinaryUrl  String
  uploadedByUserId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, category])
}

// Real, persisted in-app notifications — not the mock decorative bell. A
// notification always belongs to one user (never broadcast-stored; a
// "everyone with documents.view" event writes one row per recipient), so
// read/unread state is naturally per-person.
model Notification {
  id             String    @id @map("_id")
  organizationId String
  userId         String
  title          String
  body           String
  // Mirrors ActivityKind on the Dashboard, plus a couple of Notification-only
  // kinds (e.g. 'company') — just a string, not a Prisma enum, matching every
  // other status/type field in this schema.
  kind           String
  // Where clicking the notification should take you — a relative frontend
  // path (e.g. "/dashboard/leave"). Null when there's nowhere meaningful to go.
  link           String?
  read           Boolean   @default(false)
  createdAt      DateTime  @default(now())

  @@index([organizationId, userId, createdAt])
}

model LeaveRequest {
  id              String    @id @map("_id")
  organizationId  String
  employeeId      String
  type            String // ANNUAL | SICK | PERSONAL | UNPAID
  // Plain YYYY-MM-DD — inclusive range, no time-of-day meaning for a leave day.
  startDate       String
  endDate         String
  days            Int
  reason          String
  status          String // PENDING | APPROVED | REJECTED
  requestedAt     DateTime  @default(now())
  decidedByUserId String?
  decidedAt       DateTime?

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
}
