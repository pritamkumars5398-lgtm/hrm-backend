// Phase 1 persists ONLY access-control data: users, organisations, invites.
// There are deliberately no models for employees, attendance, payroll, leave,
// performance or reports — that is HR business data and stays mock-only until
// Phase 2 (CLAUDE.md §11.4).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model User {
  // A plain string _id, not an ObjectId, so seeded ids stay readable (usr-1).
  id             String  @id @map("_id")
  // null between signup and creating the company (§11.2).
  organizationId String?
  email          String  @unique
  // bcrypt hash. Empty for Google accounts, which have no local password.
  passwordHash   String
  name           String
  jobTitle       String
  role           String
  avatarInitials String
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

model Organization {
  id        String   @id @map("_id")
  name      String
  address   String
  industry  String
  ownerId   String
  createdAt DateTime @default(now())
}

model Invite {
  id             String   @id @map("_id")
  organizationId String
  email          String
  role           String
  status         String
  // The credential that grants access to an organisation — unique and unguessable.
  token          String   @unique
  invitedBy      String
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([organizationId])
}
