# Copy to `.env`. These are SERVER-side values — unlike the frontend's VITE_ vars,
# nothing here is exposed to the browser. This is where every secret belongs.
# Nothing in this file may be moved into the frontend.

# --- Auth -------------------------------------------------------------------
# Signing key for the JWT. Anyone who has it can mint a valid session for any
# user, so treat it like a password. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# How long a session lasts before it must be re-issued.
JWT_EXPIRES_IN=7d

# --- Database ---------------------------------------------------------------
# MongoDB Atlas connection string. MUST include a database name in the path
# (…mongodb.net/keystone), or Prisma rejects it.
MONGO_URI=

# --- CORS -------------------------------------------------------------------
# Where the frontend runs. Comma-separated. Must be explicit origins (not *),
# because the auth cookie is sent with credentials — a wildcard is rejected by
# the browser. If the frontend ends up on a port that is not listed here, every
# auth call fails CORS and looks like "the server is down".
# The FIRST entry is also used to build invite links.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

PORT=3000
NODE_ENV=development

# --- Google OAuth -----------------------------------------------------------
# The client ID is duplicated in the frontend (VITE_GOOGLE_CLIENT_ID) — that copy
# is public and fine. The SECRET belongs here and only here: it is what proves to
# Google that the token exchange is coming from our server and not from someone
# who copied our client ID out of the browser bundle.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudinary (Phase 2 — file uploads) ------------------------------------
# The API secret signs upload requests. If it ever reaches the browser, anyone can
# upload to (and delete from) your Cloudinary account. Keep it server-side and let
# the backend sign uploads for the client.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
