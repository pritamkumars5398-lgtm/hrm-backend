# Copy to `.env`. These are SERVER-side values — unlike the frontend's VITE_ vars,
# nothing here is exposed to the browser. Never move JWT_SECRET into the frontend.

# Signing key for the JWT. Use a long random string; anyone who has it can mint
# a valid session for any user. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# How long a session lasts before it must be re-issued.
JWT_EXPIRES_IN=7d

# Where the frontend runs. Comma-separated. Must be explicit origins (not *),
# because the auth cookie is sent with credentials — a wildcard is rejected by
# the browser. If the frontend ends up on a port that is not listed here, every
# auth call fails CORS and looks like "the server is down".
# The FIRST entry is also used to build invite links.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

PORT=3000
NODE_ENV=development
